{
  "info": {
    "name": "Galala IAAS Student APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.success && data.data && data.data.token) {",
                  "    pm.environment.set(\"token\", data.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"student_id\": \"YOUR_STUDENT_ID\",\n    \"password\": \"YOUR_PASSWORD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/student/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "student",
                "login"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/student/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "student",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/student/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "student",
                "profile"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Vehicle",
      "item": [
        {
          "name": "Vehicle State",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/student/vehicle",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "student",
                "vehicle"
              ]
            }
          }
        },
        {
          "name": "Submit Vehicle Request",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"vehicle_type\": \"Car\",\n    \"vehicle_model\": \"Toyota Corolla\",\n    \"vehicle_color\": \"White\",\n    \"plate_number\": \"ABC-123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/student/vehicle-requests",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "student",
                "vehicle-requests"
              ]
            }
          }
        },
        {
          "name": "Vehicle History",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/student/vehicle-requests/history",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "student",
                "vehicle-requests",
                "history"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Gate",
      "item": [
        {
          "name": "Gate Vehicle Access",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-GATE-API-KEY",
                "value": "{{gate_api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"OCR\": \"س م ١ ٤ ٦ ٩\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/gate/vehicle-access/check",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "gate",
                "vehicle-access",
                "check"
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "gate_api_key",
      "value": ""
    }
  ]
}
