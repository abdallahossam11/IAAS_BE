APP_NAME="Galala IAAS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iaas_db
DB_USERNAME=root
DB_PASSWORD=

# Initial Admin Seeder Configuration
ADMIN_NAME="Super Admin"
ADMIN_EMAIL="admin@galala.edu.eg"
ADMIN_PASSWORD="your_secure_password_here"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
FRONTEND_URL=http://127.0.0.1:5500

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

GATE_API_KEY=change_this_to_strong_random_secret

# Redis — required in Docker environments
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_this_to_a_strong_random_secret
REDIS_QUEUE_RETRY_AFTER=510

# Chatbot V1
AI_CHAT_DRIVER=fake
# Supported values: fake | http  (use "http" only when real AI endpoints and tokens are configured)
AI_CHAT_QUEUE=ai-chat

STUDENT_AI_API_URL=
STUDENT_AI_API_TOKEN=

GUEST_AI_API_URL=
GUEST_AI_API_TOKEN=

AI_CONNECT_TIMEOUT_SECONDS=10
AI_RESPONSE_TIMEOUT_SECONDS=420

CHAT_MAX_MESSAGE_LENGTH=4000

GUEST_SESSION_TTL_SECONDS=86400
GUEST_PENDING_TTL_SECONDS=600

GUEST_MESSAGE_THROTTLE_REQUESTS=10
GUEST_MESSAGE_THROTTLE_MINUTES=1
