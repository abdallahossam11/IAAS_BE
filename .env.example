APP_NAME="Galala IAAS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-server-domain.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=iaas_db
DB_USERNAME=iaas_user
DB_PASSWORD=change_this_to_a_strong_db_password

# Initial Admin Seeder Configuration
ADMIN_NAME="Super Admin"
ADMIN_EMAIL="admin@galala.edu.eg"
ADMIN_PASSWORD="change_this_to_a_strong_admin_password"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Redis — required for queue and cache
# In Docker Compose, set REDIS_HOST to the Redis service name (e.g. "redis").
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=change_this_to_a_strong_random_secret
REDIS_PORT=6379
REDIS_QUEUE_RETRY_AFTER=510

SANCTUM_STATEFUL_DOMAINS=your-frontend-domain.example.com
FRONTEND_URL=https://your-frontend-domain.example.com

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@galala.edu.eg"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Gate API — used by the physical gate hardware to verify vehicle access
GATE_API_KEY=change_this_to_strong_random_secret

# ─────────────────────────────────────────────────────────
# Chatbot AI Service Integration
# ─────────────────────────────────────────────────────────
# AI_CHAT_DRIVER: "http" uses the real FastAPI AI service.
#                 "fake" is for local dev only — never use in production.
AI_CHAT_DRIVER=http

# Queue connection and queue name for AI chat jobs.
# Must match the Laravel queue worker command (see SERVER_BACKEND_DEPLOYMENT.md).
AI_CHAT_CONNECTION=redis
AI_CHAT_QUEUE=ai-chat

# Final AI contract — single FastAPI service, single Bearer token, path-appended.
# AI_SERVICE_URL: the base URL of the Galala FastAPI AI service.
#   On our server, port 8001 is already used by another FastAPI service,
#   so the Galala AI service must listen on host port 8010.
#   From inside the Laravel Docker container, use the Docker Compose service name or host IP.
#   Example: http://ai-service:8000 (if using Compose service name)
#            http://host.docker.internal:8010 (if AI runs on host, accessed from container)
AI_SERVICE_URL=http://127.0.0.1:8010

# AI_SERVICE_TOKEN: Bearer token shared between Laravel and the AI service.
#   This value MUST exactly match the AI_SERVICE_TOKEN set in the AI FastAPI service.
#   Keep it secret — treat it like a database password.
AI_SERVICE_TOKEN=change-me-secure-token

AI_CHAT_PATH=/api/chat
AI_CHAT_SUMMARIZE_PATH=/api/chat/summarize

# Timeout for initial connection to AI service (seconds).
AI_CONNECT_TIMEOUT_SECONDS=10

# Timeout waiting for AI response (seconds). Must be > job timeout guard.
# Jobs are configured with timeout=450s; this should be <= 420s to ensure the
# job can fail cleanly before the worker kills it.
AI_RESPONSE_TIMEOUT_SECONDS=420

# ─────────────────────────────────────────────────────────
# Chat behaviour
# ─────────────────────────────────────────────────────────
# Maximum characters allowed in a single chat message (student or guest).
CHAT_MAX_MESSAGE_LENGTH=3000

# How long a guest session lives in Redis (seconds). Default: 7200 = 2 hours.
GUEST_SESSION_TTL_SECONDS=7200

# How long a guest "pending" lock lives while the AI processes (seconds).
GUEST_PENDING_TTL_SECONDS=600

# Signed-in conversations idle this long (seconds) become eligible for
# summarization via chat:summarize-idle. Default: 7200 = 2 hours.
CHAT_SUMMARIZE_IDLE_SECONDS=7200

# Guest message throttle: max requests per window (per IP / guest token).
GUEST_MESSAGE_THROTTLE_REQUESTS=10
GUEST_MESSAGE_THROTTLE_MINUTES=1
